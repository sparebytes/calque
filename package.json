{
  "name": "calque",
  "version": "1.0.0",
  "private": true,
  "description": "UI mockup overlay tool for developers",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "build": "pnpm run make-icons && electron-forge make",
    "package": "pnpm run make-icons && electron-forge package",
    "make-icons": "node scripts/make-icons.mjs",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "check:typescript": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run format:check && pnpm run check:typescript"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.5.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0"
  },
  "packageManager": "pnpm@11.9.0",
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true
  },
  "productName": "Calque"
}
